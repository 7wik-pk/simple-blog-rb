<!DOCTYPE html>
<html lang="en">
<head>
    <title>Create a new article</title>
</head>
<body>
    <h2>Create a new article</h2>
    <% if @article.errors.any? %>
        <h2>The following errors prevented the creation of the new article</h2>
        <ul>
        <% @article.errors.full_messages.each do |error_msg| %>
            <li><%= error_msg %></li>
        <% end %>
        </ul>
    <% end %>
    <%= form_with scope: :article, url: articles_path, local: true do |f| %>
    <p>
        <%= f.label :title %><br/>
        <%= f.text_field :title %>
    </p>
    <p>
        <%= f.label :desc, "Description" %><br/>
        <%= f.text_area :desc %>
    </p>
    <p>
        <%= f.submit %>
    </p>
    <% end %>
</body>
</html>