<h2>Number of articles: <%= @articles.length %></h2>
<h2>List of articles:<br></h2>
<table>
    <thead>
        <tr>
            <th>Title</th>
            <th>Description</th>
            <th colspan="3">Actions</th>
        </tr>
    </thead>
    <tbody>
        <% @articles.each do |article| %>
        <tr>
            <td> <%= article.title %> </td>
            <td> <%= article.desc %> </td>
            <td><%= link_to 'Show', article_path(article) %></td> <!-- method will be get by default-->
            <td><%= link_to 'Edit', edit_article_path(article) %></td>
            <td><%= link_to 'Delete', article_path(article), method: :delete %></td>
        </tr>
        <% end %>
    </tbody>
</table>
<br/>
<%= link_to 'Create New Article', new_article_path %>